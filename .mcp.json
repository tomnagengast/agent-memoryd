{
  "mcpServers": {
        "agent-memoryd": {
            "type": "stdio",
            "command": "sh",
            "args": [
                "-lc",
                "exec ~/.local/bin/memoryd mcp"
            ],
            "env": {
                "MEMORYD_HOME": "~/.local/share/memoryd"
            }
        }
    }
}
